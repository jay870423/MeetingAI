[Unit]
Description=MeetingAI Backend Service
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/MeetingAI
EnvironmentFile=/home/ubuntu/MeetingAI/.env
ExecStart=/home/ubuntu/MeetingAI/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8989
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
